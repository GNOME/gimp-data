# Horizontal position of the crop on Installer's install-end*.bmp
layer_windows  = 'orion_sw_aligned_cropped_4k.png'
offset_percent = 0.31

# gimp-dmg.png will be a 640:480 image.
# Please choose the crop by the top-left offset and the height.
layer_macos    = 'orion_sw_aligned_cropped_4k.png'
offset_macos_x = 781
offset_macos_y = 503
target_macos_h = 1379
